#!/usr/bin/env python3

"""Use landlock to restrict access to abstract Unix socket."""

import ctypes
import ctypes.util
import os
import struct
import sys


def fatal(msg):
    print("isolate: landlock:", msg, file=sys.stderr)
    sys.exit(1)


libc = ctypes.CDLL(ctypes.util.find_library("c"), use_errno=True)
libc.syscall.restype = ctypes.c_long

SYS_landlock_create_ruleset = 444
LANDLOCK_CREATE_RULESET_VERSION = 1
abi = libc.syscall(
    SYS_landlock_create_ruleset, None, 0, LANDLOCK_CREATE_RULESET_VERSION
)
if abi < 6:
    fatal(f"kernel ABI v{abi} < 6; abstract unix scoping unavailable")

PR_SET_NO_NEW_PRIVS = 38
if libc.prctl(PR_SET_NO_NEW_PRIVS, 1, 0, 0, 0):
    fatal(f"prctl: {os.strerror(ctypes.get_errno())}")

LANDLOCK_SCOPE_ABSTRACT_UNIX_SOCKET = 1
attr = struct.pack("QQQ", 0, 0, LANDLOCK_SCOPE_ABSTRACT_UNIX_SOCKET)
fd = libc.syscall(SYS_landlock_create_ruleset, attr, len(attr), 0)
if fd < 0:
    fatal(f"create_ruleset: {os.strerror(ctypes.get_errno())}")

SYS_landlock_restrict_self = 446
if libc.syscall(SYS_landlock_restrict_self, fd, 0):
    fatal(f"restrict_self: {os.strerror(ctypes.get_errno())}")
os.close(fd)

os.execvp(sys.argv[1], sys.argv[1:])
